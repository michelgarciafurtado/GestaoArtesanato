@page
@model LojaApp.Pages.CrudProdutos.EditarModel
@{
    ViewData["Title"] = "Editar Produto";
}
@if (TempData["Mensagem"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensagem"]
    </div>
}

<h4>Editar Produto</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data" asp-page-handler="AddProduct">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <input type="hidden"  asp-for="Produto.IdProduto" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Produto.NomeProduto" class="control-label"></label>
                <input asp-for="Produto.NomeProduto" class="form-control" />
                <span asp-validation-for="Produto.NomeProduto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.Descricao" class="control-label"></label>
                <input asp-for="Produto.Descricao" class="form-control" />
                <span asp-validation-for="Produto.Descricao" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.IdCategoria" class="control-label">Categoria</label>
                <select class="form-select"
                        asp-for="Produto.IdCategoria"
                        asp-items="Model.SelectCategoria"></select>
                <span asp-validation-for="Produto.IdCategoria" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.PesoProduto" class="control-label"></label>
                <input asp-for="Produto.PesoProduto" class="form-control" />
                <span asp-validation-for="Produto.PesoProduto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.medidaEnum" class="control-label">Tipo de Medida</label>
                <select class="form-select"
                        asp-for="Produto.medidaEnum"
                        asp-items="Html.GetEnumSelectList<LojaApp.Models.Enums.TpMedidaEnum>()"></select>
                <span asp-validation-for="Produto.medidaEnum" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.MargemLucro" class="control-label"></label>
                <input asp-for="Produto.MargemLucro" class="form-control" />
                <span asp-validation-for="Produto.MargemLucro" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.Preco" class="control-label"></label>
                <input asp-for="Produto.Preco" class="form-control" readonly/>
                <span asp-validation-for="Produto.Preco" class="text-danger"></span>
            </div>
            <!-- INICIO Form-Group Imagem --> <div class="form-group">
                <div style="display:flex; gap:20px">
                    <div style="flex:1;">
                        <label>Imagem Principal</label>
                        <input type="file" name="ImagemUpload" class="form-control" onchange="previewImage(event)" />
                    </div>
                    <div style="flex:1; text-align:center;">
                        <label>Preview</label></br>
                        <img src="@(Model.Produto?.UrlImg ?? "")" alt="Imagem do produto" id="preview" style="width:150px; height:150px; object-fit:cover;" />
                        <input type="hidden" asp-for="Produto.UrlImg" />
                    </div>
                </div>
            </div><!-- FIM Form-Group Imagem -->
            <div class="form-group">
                <label class="control-label">Custos (Ingrediente + Custos + Margem de lucro) = @(Model.Produto.CalcularPrecoProduto() != null ? Model.Produto.CalcularPrecoProduto() : "0,00")</label>

            </div>
            <p>
                <a asp-page="/CrudIngredientes/Create"
                   asp-route-IdProduto="@(Model.Produto?.IdProduto ?? "0")">
                    Add Ingrediente
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-square" viewBox="0 0 16 16">
                        <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4" />
                    </svg>
                </a>
            <p>
                <a asp-page="/CrudCustosProdutos/Create"
                   asp-route-IdProduto="@(Model.Produto?.IdProduto ?? "0")">
                    Add Custo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-square" viewBox="0 0 16 16">
                        <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4" />
                    </svg>
                </a>
            </p>
            </p>
            <table class="table">
                <thead>
                    <tr>
                        <th>
                            Substancia
                        </th>
                        <th>
                           Quantidade
                        </th>
                        <th>
                            

                        </th>
                        <th>
                            Vl Un.
                        </th>
                        <th>
                            CustoItem
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Produto.ListaIngredientes.Any() || Model.Produto.ListaIngredientes != null)
                    {
                        foreach (var ingrediente in Model.Produto.ListaIngredientes)
                        {
                            <tr>
                                <td>@ingrediente.Substancia.Descricao</td>
                                <td>@ingrediente.QtdIngrediente</td>
                                <td>@ingrediente.Substancia.TpMedida</td>
                                <td>@ingrediente.Substancia.VlUn</td>
                                <td>@ingrediente.CalcularCustoIngrediente()</td>
                                <td>
                                    <button type="submit" asp-page-handler="Deleteingrediente"
                                            asp-route-IdIngrediente="@ingrediente.IdIngrediente"
                                            class="btn btn-danger">
                                        Excluir
                                     </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">Nenhum ingrediente cadastrado</td>
                        </tr>
                    }
                </tbody>

            </table>
            <table class="table">
                <thead>
                    <tr>
                        <th>
                            Descrição
                        </th>
                        <th>
                            Valor
                        </th>
                        <th>

                        </th> 
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Produto.ListaCustos.Any() || Model.Produto.ListaCustos != null)
                    {
                        foreach (var custo in Model.Produto.ListaCustos)
                        {
                            <tr>
                                <td>@custo.DescricaoCusto</td>
                                <td>@custo.ValorCusto</td>
                                <td>
                                    <button type="submit" asp-page-handler="DeleteCusto"
                                            asp-route-IdCusto="@custo.IdCusto"
                                            class="btn btn-danger">
                                        Excluir
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">Nenhum ingrediente cadastrado</td>
                        </tr>
                    }
                </tbody>

            </table>
            <div class="form-group">
                <button type="submit"
                         value="Salvar"
                        asp-page-handler="AddProduct"
                        class="btn btn-primary"
                >
                    Salvar
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-floppy" viewBox="0 0 16 16">
                        <path d="M11 2H9v3h2z" />
                        <path d="M1.5 0h11.586a1.5 1.5 0 0 1 1.06.44l1.415 1.414A1.5 1.5 0 0 1 16 2.914V14.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13A1.5 1.5 0 0 1 1.5 0M1 1.5v13a.5.5 0 0 0 .5.5H2v-4.5A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5V15h.5a.5.5 0 0 0 .5-.5V2.914a.5.5 0 0 0-.146-.353l-1.415-1.415A.5.5 0 0 0 13.086 1H13v4.5A1.5 1.5 0 0 1 11.5 7h-7A1.5 1.5 0 0 1 3 5.5V1H1.5a.5.5 0 0 0-.5.5m3 4a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5V1H4zM3 15h10v-4.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5z" />
                    </svg>

                </button>
            </div>
        </form>
    </div>

</div>

<script>
    function previewImage(event) {
        var input = event.target;
        var preview = document.getElementById('preview');

        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

   Globalize.culture("pt-BR"); // Sobrescreve o método number do jQuery Validation para usar Globalize 
   $.validator.methods.number = function (value, element) 
   { 
       return this.optional(element) || !isNaN(Globalize.parseFloat(value)); 
   }; 
</script>
<script>
    $(function () {
        // 1. Faz o validador do jQuery aceitar vírgula
        $.validator.methods.number = function (value, element) {
            return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:[\s.,]\d{3})+)(?:[.,]\d+)?$/.test(value);
        };
    });
</script>