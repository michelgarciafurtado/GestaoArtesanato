@page
@model LojaApp.Pages.CrudSubstancias.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Substancia</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Substancia.IdSubstancia" />
            <div class="form-group">
                <label asp-for="Substancia.Descricao" class="control-label"></label>
                <input asp-for="Substancia.Descricao" class="form-control" />
                <span asp-validation-for="Substancia.Descricao" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Substancia.VlUn" class="control-label"></label>
                <input asp-for="Substancia.VlUn" type="text" class="form-control"
                       data-val="true" data-val-number="O campo Valor deve ser um número." />
                <span asp-validation-for="Substancia.VlUn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Substancia.TpMedida" class="control-label"></label>
                <select asp-for="Substancia.TpMedida"
                        class="form-control"
                        asp-items="Html.GetEnumSelectList<LojaApp.Models.Enums.TpMedidaEnum>()"></select>
                <span asp-validation-for="Substancia.TpMedida" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Substitui a regra de validação de números para aceitar o formato brasileiro
        $.validator.methods.number = function (value, element) {
            return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:[\s\.,]\d{3})+)(?:[\.,]\d+)?$/.test(value);
        };

        // Correção específica para range (opcional, mas evita erros em decimais)
        $.validator.methods.range = function (value, element, param) {
            var globalizedValue = value.replace(",", ".");
            return this.optional(element) || (globalizedValue >= param[0] && globalizedValue <= param[1]);
        };
    </script>
}
