@page
@model LojaApp.Pages.PedidoModel
@{
}

 
<!DOCTYPE html> 
<html>
<head> 
    <meta charset="utf-8" /> 
    <title>Detalhes do Produto</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    </head>
    <body class="bg-light">
        <div class="container mt-5"> 

            <div class="card shadow-sm"> 
                <form method="post">
                <div class="card-header bg-primary text-white"> 
                    <h4>Detalhes do Produto</h4> 
                    </div> 
                    <div class="card-body"> 
                        <div class="row mb-3">
                            <div class="col-md-6"> 
                                <label class="form-label">Nome</label>
                                <input class="form-control" value="@Model.Produto.NomeProduto" readonly /> 
                                </div> <div class="col-md-6"> <label class="form-label">Categoria</label>
                                    <input class="form-control" value="@Model.Produto.Categoria?.Descricao" readonly />
                                    </div> </div> <div class="row mb-3"> <div class="col-md-12"> 
                                        <label class="form-label">Descrição</label>
                                        <textarea class="form-control" rows="2" readonly>@Model.Produto.Descricao</textarea>
                                    </div> 
                                    </div> 
                                    <div class="row mb-3"> 
                                        <div class="col-md-4"> 
                                            <label class="form-label">Peso</label> 
                                            <input class="form-control" value="@Model.Produto.PesoProduto" readonly />
                                        </div>
                                        <div class="col-md-4"> 
                                            <label class="form-label">Medida</label>
                                            <input class="form-control" value="@Model.Produto.medidaEnum" readonly /> 
                                        </div> 
                                        <div class="col-md-4"> 
                                            <label class="form-label">Preço</label> 
                                            <input class="form-control" value="@Model.Produto.Preco.ToString("C")" readonly /> 
                                        </div> 
                                        </div> 
                                        <div class="row mb-3">
                                            <div class="col-md-12 text-center"> 
                                                @if (!string.IsNullOrEmpty(Model.Produto.UrlImg))
                                                { 
                                                    <img src="@Model.Produto.UrlImg" alt="Imagem do Produto" class="img-fluid rounded shadow-sm" style="max-height:250px;" />
                                                } 
                                             </div>
                                        </div> 
                                        <div class="row mb-3">
                                        <div class="row mb-3">
                                            <button type="submit" name="name" class="btn btn alert-success">Enviar Pedido</button>
                                        </div>  
                                        </div>
                                      </div> 
               
            </form>
                                   </div> 
                                   
                                </div>
                              
                              </body> 
                                                </html>
