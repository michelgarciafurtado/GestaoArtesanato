@page
@model LojaApp.Pages.CrudEntradaMateriais.IndexModel

@{
    ViewData["Title"] = "Lista de entrada de materias";
}
@{
        if (TempData["Mensagem"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensagem"]
        </div>
    }
}

<h1>index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.EntradaMaterial[0].DataEntrada)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EntradaMaterial[0].Substancia)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EntradaMaterial[0].Quantidade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EntradaMaterial[0].PesoUn)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EntradaMaterial[0].TipoMedida)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EntradaMaterial[0].ValorUn)
            </th>
            <th>Valor Total</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.EntradaMaterial) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DataEntrada)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Substancia.Descricao)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quantidade)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PesoUn)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TipoMedida)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ValorUn)
            </td>
            <td>
                @item.ValorTotal
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.IdEntrada">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.IdEntrada">Details</a> |
                    <!-- Excluir -->
                    <form method="post" class="d-inline">
                        <button type="submit"
                                asp-page-handler="DeleteEntrada"
                                asp-route-IdEntrada="@item.IdEntrada"
                                class="btn btn-sm btn-danger"
                                title="Excluir">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                 fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0
                                                         0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5
                                                         0 0 0 1 0z" />
                                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1
                                                         1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0
                                                         1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5
                                                         3h11V2h-11z" />
                            </svg>
                        </button>
                    </form>
            </td>
        </tr>
}
    </tbody>
</table>
