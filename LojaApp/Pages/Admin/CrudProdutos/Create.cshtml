@page
@model LojaApp.Pages.CrudProdutos.CreateModel

@{
    ViewData["Title"] = "Novo Produto";
}
@if(TempData["Mensagem"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensagem"]
    </div>
}

<h1 class="mb-3">Adicionar Produto</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Produto.NomeProduto" class="control-label"></label>
                <input asp-for="Produto.NomeProduto" class="form-control" />
                <span asp-validation-for="Produto.NomeProduto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.Descricao" class="control-label"></label>
                <input asp-for="Produto.Descricao" class="form-control" />
                <span asp-validation-for="Produto.Descricao" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.IdCategoria" class="control-label">Categoria</label>
                <select class="form-select"
                        asp-for="Produto.IdCategoria"
                        asp-items="Model.SelectCategoria"></select>
                <span asp-validation-for="Produto.IdCategoria" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.PesoProduto" class="control-label"></label>
                <input type="number" asp-for="Produto.PesoProduto" class="form-control" />
                <span asp-validation-for="Produto.PesoProduto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.medidaEnum" class="control-label">Tipo de Medida</label>
                <select class="form-select"
                        asp-for="Produto.medidaEnum"
                        asp-items="Html.GetEnumSelectList<LojaApp.Models.Enums.TpMedidaEnum>()"></select>
                <span asp-validation-for="Produto.medidaEnum" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.MargemLucro" class="control-label"></label>
                <input asp-for="Produto.MargemLucro" class="form-control" />
                <span asp-validation-for="Produto.MargemLucro" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.Preco" class="control-label"></label>
                <input asp-for="Produto.Preco" class="form-control" />
                <span asp-validation-for="Produto.Preco" class="text-danger"></span>
            </div>
            <!-- INICIO Form-Group Imagem --> 
            <div class="form-group">
                <div style="display:flex; gap:20px">
                    <div style="flex:1;">
                        <label>Imagem Principal</label>
                        <input type="file" name="ImagemUpload" class="form-control" onchange="previewImage(event)" />
                    </div>
                    <div style="flex:1; text-align:center;">
                        <label>Preview</label></br>
                        <img src="@(Model.Produto?.UrlImg ?? "")" 
                             alt="Imagem do produto" 
                             id="preview" 
                             style="width:150px; height:150px; object-fit:cover;"
                        />
                    </div>
                </div>
            </div><!-- FIM Form-Group Imagem -->

            <div class="form-group">
                            <input type="submit" value="Salvar" class="btn btn-success" />
             </div>
        </form>
    </div>
    
</div>

<script>
    function previewImage(event) {
        var input = event.target;
        var preview = document.getElementById('preview');

        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
<script>
    $(function () {
        // 1. Faz o validador do jQuery aceitar vírgula
        $.validator.methods.number = function (value, element) {
            return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:[\s.,]\d{3})+)(?:[.,]\d+)?$/.test(value);
        };
    });
</script>
