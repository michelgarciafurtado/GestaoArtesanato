@page
@model LojaApp.Pages.CrudProdutos.IndexModel

@{
    ViewData["Title"] = "Gerenciamento de Produtos";
}

@if (TempData["Mensagem"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensagem"]
    </div>
}

<h1 class="mb-3">Gerenciamento de Produtos</h1>
<hr />

<div class="mb-3">
    <a href="/Admin/CrudProdutos/Create" class="btn btn-success">
        Adicionar
    </a>
</div>

<div class="row">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th scope="col">Imagem</th>
                <th scope="col">@Html.DisplayNameFor(model => model.Produtos[0].NomeProduto)</th>
                <th scope="col">@Html.DisplayNameFor(model => model.Produtos[0].Categoria)</th>
                <th scope="col">@Html.DisplayNameFor(model => model.Produtos[0].PesoProduto)</th>
                <th scope="col">@Html.DisplayNameFor(model => model.Produtos[0].medidaEnum)</th>
                <th scope="col">@Html.DisplayNameFor(model => model.Produtos[0].Preco)</th>
                <th scope="col" class="text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var produto in Model.Produtos)
            {
                <tr>
                    <!-- Imagem -->
                    <td>
                        <img src="~/@Html.DisplayFor(model => produto.UrlImg)"
                             alt="Imagem do produto"
                             class="img-thumbnail"
                             style="width:80px; height:80px; object-fit:cover;" />
                    </td>

                    <!-- Dados -->
                    <td>@Html.DisplayFor(model => produto.NomeProduto)</td>
                    <td>@Html.DisplayFor(model => produto.Categoria.Descricao)</td>
                    <td>@Html.DisplayFor(model => produto.PesoProduto)</td>
                    <td>@Html.DisplayFor(model => produto.medidaEnum)</td>
                    <td> R$ @Html.DisplayFor(model => produto.Preco)</td>

                    <!-- Ações -->
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-2">
                            <!-- Editar -->
                            <form asp-page="./Editar" method="get" class="d-inline">
                                <input type="hidden" name="IdProduto" value="@produto.IdProduto" />
                                <button type="submit" class="btn btn-sm btn-light" title="Editar">
                                  Editar
                                </button>
                            </form>

                            <!-- Adicionar Imagens -->
                            <form asp-page="./GenImagens" method="get" class="d-inline">
                                <input type="hidden" name="IdProduto" value="@produto.IdProduto" />
                                <button type="submit" class="btn btn-sm btn-info" title="AddImagens">
                                  Ad. Imagens
                                </button>
                            </form>

                            <!-- Excluir -->
                            <form method="post" class="d-inline">
                                <button type="submit"
                                        asp-page-handler="DeleteProduto"
                                        asp-route-IdProduto="@produto.IdProduto"
                                        class="btn btn-sm btn-danger"
                                        title="Excluir">
                                    Excluir
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
