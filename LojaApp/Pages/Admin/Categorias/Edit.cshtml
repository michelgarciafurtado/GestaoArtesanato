@page
@model LojaApp.Pages.Categorias.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edição</h1>

<h4>Categoria</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Categoria.IdCategoria" />
            <div class="form-group">
                <label asp-for="Categoria.Descricao" class="control-label"></label>
                <input asp-for="Categoria.Descricao" class="form-control" />
                <span asp-validation-for="Categoria.Descricao" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Atualizar" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>

<div>
    <a class="btn btn-info" asp-page="./Index">Voltar</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
