@page
@model LojaApp.Pages.Categorias.DetailsModel

@{
    ViewData["Title"] = "Details";
}
@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">
        @Model.MensagemErro
    </div>
}
@if (!string.IsNullOrEmpty(Model.MensagemSucesso))
{
    <div class="alert alert-success">
        @Model.MensagemSucesso
    </div>
}
<h1>Detalhes</h1>

<div>
    <h4>Categoria</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Categoria.Descricao)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Categoria.Descricao)
        </dd>
    </dl>
</div>
<div>
    <a class="btn btn-success" asp-page="./Edit" asp-route-id="@Model.Categoria.IdCategoria">Edit</a> |
    <a class="btn btn-info" asp-page="./Index">Back to List</a>
</div>
