@page
@model LojaApp.Pages.CrudIngredientes.DeleteModel

@{
    ViewData["Title"] = "Excluir";
}

<h1>Exclusão</h1>

<h3>Tem certeza que deseja excluir?</h3>
<div>
    <h4>Ingrediente</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ingrediente.QtdIngrediente)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ingrediente.QtdIngrediente)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Ingrediente.IdIngrediente" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Voltar</a>
    </form>
</div>
