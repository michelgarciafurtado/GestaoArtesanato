@page
@model LojaApp.Pages.CrudIngredientes.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Ingrediente</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Ingrediente.IdIngrediente" />
            <div class="form-group">
                <label asp-for="Ingrediente.QtdIngrediente" class="control-label"></label>
                <input asp-for="Ingrediente.QtdIngrediente" class="form-control" />
                <span asp-validation-for="Ingrediente.QtdIngrediente" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        Globalize.culture("pt-BR"); // Sobrescreve o método number do jQuery Validation para usar Globalize
        $.validator.methods.number = function (value, element)
        {
            return this.optional(element) || !isNaN(Globalize.parseFloat(value));
        };
    </script>
    <script>
                $(function () {
                    // 1. Faz o validador do jQuery aceitar vírgula
                    $.validator.methods.number = function (value, element) {
                        return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:[\s.,]\d{3})+)(?:[.,]\d+)?$/.test(value);
                    };
                });
    </script>
}
