@page
@model IndexModel
@{
    ViewData["Title"] = "Mellius - Saboaria Artesanal";
}

<nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow sticky-top">
    <div class="container-fluid">
        <ul id="menu-categorias" class="navbar-nav flex-row flex-nowrap overflow-x-auto w-100">
            @foreach(var cat in Model.Categorias)
            {
                <li class="nav-item text-nowrap" >
                    <a class="nav-link" asp-page-handler="FilterCateg" asp-route-IdCateg="@cat.IdCategoria">
                        @cat.Descricao
                    </a>
                   
                </li>
            }
            
        </ul>
    </div>
</nav>
<div class="destaque-loja text-center py-5">
    <h1 class="display-4 loja-titulo">Mellius Saboaria Artesanal</h1>
    <p class="loja-subtitulo">
        @Html.Raw(@Model.IndexVM.TextoCabecalho)
    </p>
    <a href="#produtos" class="btn btn-loja-banner">Descubra agora</a>
</div>


@if (!string.IsNullOrEmpty(Model.Mensagem))
{
    <div class="alert alert-success text-center mt-3">
        @Model.Mensagem
    </div>
}


<div id="produtos" class="container mt-5">
    <div class="row g-4">
        @foreach (var produto in Model.Produtos)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card produto-card h-100 shadow-sm">
                    <img src="@produto.UrlImg" class="card-img-top produto-img" alt="imagem do produto" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-center">@produto.NomeProduto</h5>
                        <p class="card-text text-muted text-center mb-1">Categoria: @produto.Categoria.Descricao</p>
                        <p class="card-text text-center">@produto.Descricao</p>
                        <p class="card-text text-center">Peso: @produto.PesoProduto @produto.medidaEnum.ToString()</p>
                        <p class="card-text preco text-center">Preço: R$ @produto.Preco</p>
                        <div class="mt-auto text-center">
                            <a asp-page="./DetalhesProduto" asp-route-IdProduto="@produto.IdProduto" class="btn btn-loja">Saiba Mais</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>


