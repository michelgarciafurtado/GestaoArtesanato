@page
@model LojaApp.Pages.DetalhesProdutoModel
@{
    ViewData["Title"] = "Detalhes do Produto";
}

<div class="container mt-5 mb-5">
    <div class="row produto-card p-4 shadow-sm">

        <div class="col-md-6 mb-4">
            <div class="position-relative">
                <img id="mainImage" src="@(string.IsNullOrEmpty(Model.Product.UrlImgPrincipal) ? "/img/sem-foto.png" : Model.Product.UrlImgPrincipal)"
                     class="img-fluid rounded shadow-sm w-100 produto-img-detalhe"
                     alt="@Model.Product.NomeProduto">
            </div>

            @if (Model.Product.Imagens != null && Model.Product.Imagens.Any())
            {
                <div class="d-flex mt-3 gap-2 overflow-auto">
                    @foreach (var urlImg in Model.Product.Imagens)
                    {
                        <img src="@urlImg" class="img-thumbnail thumb" style="width: 80px; height: 80px; object-fit: cover;">
                    }
                </div>
            }
        </div>

        <div class="col-md-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="./Index" class="text-muted text-decoration-none">Loja</a></li>
                    <li class="breadcrumb-item active text-brown" aria-current="page">@Model.Product.Categoria?</li>
                </ol>
            </nav>

            <h1 class="loja-titulo mb-2">@Model.Product.NomeProduto</h1>
            <p class="text-muted mb-4">@Model.Product.Descricao</p>

            <div class="d-flex align-items-center mb-4">
                <span class="preco fs-2 me-3">R$ @Model.Product.Preco.ToString("F2")</span>
                <span class="badge bg-secondary p-2">
                    @Model.Product.Peso @Model.Product.Medida
                </span>
            </div>

            <hr />

            @if (Model.Product.Ingredientes != null && Model.Product.Ingredientes.Any())
            {
                <div class="mb-4">
                    <h5 class="loja-titulo" style="font-size: 1.1rem;">Ingredientes:</h5>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var ing in Model.Product.Ingredientes)
                        {
                            <span class="badge border text-dark fw-normal" style="background-color: #fdfaf8;">
                                @ing
                            </span>
                        }
                    </div>
                </div>
            }

            <div class="d-grid gap-2 d-md-flex mt-5">
                
                        <a asp-page="./Pedido" 
                        asp-route-id="@Model.Product.IdProduto"
                   class="btn btn-loja-banner flex-grow-1">
                    <i class="bi bi-cart-plus"></i> 
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-whatsapp" viewBox="0 0 16 16">
                        <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232" />
                    </svg>
                    Solicitar Contato
                </a>
                <a asp-page="./Index" class="btn btn-outline-secondary rounded-pill px-4">
                    Voltar
                </a>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const mainImage = document.getElementById("mainImage");
        const thumbnails = document.querySelectorAll(".thumb");

        thumbnails.forEach(thumb => {
            thumb.addEventListener("click", function () {
                mainImage.src = this.src;

                thumbnails.forEach(t => t.classList.remove("border", "border-primary"));
                this.classList.add("border", "border-primary");
            });
        });
    });
</script>
